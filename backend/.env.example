APP_NAME="ERP Africa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Africa/Abidjan

# ── Base de données ───────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=erp_development
DB_USERNAME=erp
DB_PASSWORD=secret

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# ── Queue ─────────────────────────────────────
QUEUE_CONNECTION=redis
HORIZON_PREFIX=erp_horizon

# ── Cache ─────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Mail (Mailpit en dev) ─────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS="noreply@votreerp.com"
MAIL_FROM_NAME="ERP Africa"

# ── Stockage S3 (MinIO en dev) ────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=erp_admin
AWS_SECRET_ACCESS_KEY=erp_secret_123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=erp-uploads
AWS_URL=http://localhost:9000
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Multitenancy ──────────────────────────────
TENANCY_DATABASE_AUTO_CREATE=true

# ── Chiffrement connecteurs ───────────────────
CONNECTOR_ENCRYPTION_KEY=

# ── Sentry (optionnel) ────────────────────────
SENTRY_LARAVEL_DSN=

# ── Logs ──────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
